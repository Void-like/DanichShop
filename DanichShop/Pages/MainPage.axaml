<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
              xmlns:vm="using:DanichShop.ViewModels"
             x:DataType="vm:MainWindowViewModel"
             x:Class="DanichShop.MainPage">
      <UserControl.DataContext>
        <vm:MainWindowViewModel/>
    </UserControl.DataContext>
    <Grid RowDefinitions="70,30,*" ColumnDefinitions="*,*,*">

        <Border Background="#2c3e50" Padding="15" Grid.ColumnSpan="3">
         <TextBlock Text="Корзина" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="2" Grid.ColumnSpan="3" Margin="10" >
            <ItemsControl ItemsSource="{Binding Korzinalist}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                     
                        <Border Width="220" Height="320" Background="White" Margin="8" BorderBrush="#e0e0e0" BorderThickness="1">
                            
                            <Grid RowDefinitions="160,Auto,Auto,Auto">
                                
                              
                                <Border Grid.Row="0" Background="White" >
                                    <Image Source="{Binding PictureImage}"  Stretch="Uniform" VerticalAlignment="Center" MaxHeight="140"/>
                                </Border>
                                
                               
                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="10,10,10,5" Foreground="#1a1a1a"/>
                                
                                
                                <TextBlock Grid.Row="2"  Text="{Binding Description}" FontSize="11"  TextWrapping="Wrap" Margin="10,0,10,5" Foreground="#666" MaxHeight="35"/>
                                
                           
                                <Grid Grid.Row="3" Margin="10,0,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Cost, StringFormat='Цена: {0}'}"  FontSize="16"  FontWeight="Bold" Foreground="#cc0000" VerticalAlignment="Center"/>
                                    
                                    <Button Grid.Column="1"  Content="Купить" Background="#cc0000" Foreground="White" Padding="12,5" FontSize="12" FontWeight="Bold"/>
                                    <Button Grid.Column="2"  Content="Убрать из корзины" Background="#cc0000" Foreground="White" Padding="12,5" FontSize="12" FontWeight="Bold"/>
                                </Grid>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        


	 


  </Grid>
</UserControl>
