<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:DanichShop.ViewModels"
             x:DataType="vm:MainWindowViewModel"
             x:Class="DanichShop.MainPage"
             Background="#F0F2F5">
    
    <UserControl.DataContext>
        <vm:MainWindowViewModel/>
    </UserControl.DataContext>
    
    <UserControl.Styles>
        <Style Selector="Border.item-card">
            <Setter Property="Width" Value="240"/>
            <Setter Property="Height" Value="360"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        
        <Style Selector="Button.buy-btn">
            <Setter Property="Background" Value="#27ae60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        
        <Style Selector="Button.buy-btn:pointerover">
            <Setter Property="Background" Value="#219a52"/>
        </Style>
        
        <Style Selector="Button.remove-btn">
            <Setter Property="Background" Value="#e74c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.remove-btn:pointerover">
            <Setter Property="Background" Value="#c0392b"/>
        </Style>
        
        <Style Selector="Button.clear-btn">
            <Setter Property="Background" Value="#e74c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style Selector="Button.clear-btn:pointerover">
            <Setter Property="Background" Value="#c0392b"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="#F0F2F5">
        
     
        <Border Grid.Row="0" Background="#2c3e50" Padding="25,20">
            <StackPanel>
                <TextBlock Text="Корзина" FontSize="24" FontWeight="Bold" Foreground="White" LetterSpacing="1"/>
                <TextBlock Text="Товары, ожидающие покупки"  FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1" Background="White" Padding="20,20" Margin="0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Korzinalist.Count, StringFormat='Всего товаров: {0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" VerticalAlignment="Top"/>
                 <TextBlock Grid.Column="1" Text="{Binding ThisUser.Balance, StringFormat='Баланс: {0:C}'}" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Grid.Column="1" FontSize="18" FontWeight="Bold" Foreground="#27ae60" VerticalAlignment="Center" Margin="0,0,0,0"/>
                
                <Button Grid.Column="2" Classes="clear-btn" Content="Очистить корзину" Command="{Binding ClearKorzinaCommand}" Margin="160,0,50,0"/>
                 
            </Grid>
        </Border>
        
  
        <ScrollViewer Grid.Row="2" Margin="15,15">
            <ItemsControl ItemsSource="{Binding Korzinalist}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="item-card">
                            <Grid RowDefinitions="150,45,40,30,*">
                                
                          
                                <Border Grid.Row="0" Background="#F9FAFB" CornerRadius="12,12,0,0">
                                    <Image Source="{Binding PictureImage}" Stretch="Uniform" VerticalAlignment="Center" MaxHeight="130" Margin="10"/>
                                </Border>
                                
                           
                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"  Margin="10,8,10,0"  Foreground="#1a1a1a" MaxHeight="40"/>
                                
                         
                                <TextBlock Grid.Row="2"  Text="{Binding Description}" FontSize="11"  TextWrapping="Wrap" Margin="10,5,10,0" Foreground="#6B7280" MaxHeight="35"/>
                                
                             
                                <Border Grid.Row="3"  Background="#F9FAFB" CornerRadius="8" Margin="10,5,10,5" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Количество:" FontSize="12" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Count}" FontSize="12" FontWeight="Bold" Foreground="#27ae60" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                            
                                <Border Grid.Row="4"  Background="White" CornerRadius="0,0,12,12" Padding="10,5,10,12">
                                    
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                       
                                        <TextBlock Grid.Column="0" Text="{Binding TotalPrice, StringFormat='|{0:C}|'}" FontSize="16"  FontWeight="Bold" Foreground="#27ae60" VerticalAlignment="Center"/>
                                        
                                  
                                        <Button Grid.Column="1" Classes="buy-btn" Content="Купить" Command="{Binding  $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).BuyItem}" CommandParameter="{Binding Id}"/>
                                        
                               
                                        <Button Grid.Column="2" Classes="remove-btn" Content="Убрать" Command="{Binding  $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RemoveKorzina}" CommandParameter="{Binding Id}"/>
                                    </Grid>
                                </Border>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        
    </Grid>
</UserControl>