<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        xmlns:vm="using:DanichShop.ViewModels"
        x:Class="DanichShop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowCaption,StringFormat='DanichShop - {0}'}"
        MinWidth="450" MinHeight="550"
        Background="#F0F2F5">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    
    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
         <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#667eea"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
         <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
         </Style>

        
        <Style Selector="Button.nav-button:pressed">
            <Setter Property="Background" Value="#E5E7EB"/>
        </Style>
        <Style Selector="TextBlock">
           <Setter Property="FontSize" Value="13"/>
           <Setter Property="Foreground" Value="#374151"/>
           <Setter Property="FontWeight" Value="SemiBold"/>
           <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
        
         
      
    </Window.Styles>
    
    <Grid RowDefinitions="Auto,*,Auto">
        
      
        <Border Grid.Row="0" Background="#2c3e50" Padding="25,20">
            <StackPanel>
                <TextBlock Text="DanichShop" FontSize="24" FontWeight="Bold" Foreground="White" LetterSpacing="1"/>
                <TextBlock Text="Магазин цифровых товаров и услуг" FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
       
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Margin="40" MaxWidth="450" HorizontalAlignment="Center" VerticalAlignment="Center">
                
                <Border Background="White"  CornerRadius="24" Padding="0" Height="500" Width="550">
                    
                    <StackPanel>
    
                        <StackPanel Margin="100,100,100,100" Spacing="10">
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Логин"/>
                                <TextBox Watermark="Введите логин" Text="{Binding Login}"/>
                            </StackPanel>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Пароль" />
                                <TextBox Watermark="Введите пароль" Text="{Binding Password}" PasswordChar="●"/>
                            </StackPanel>
                            
                            <Button Content="Войти"  Command="{Binding AuthCommand}" Background="#667eea" Foreground="White" Height="48" Margin="0,10,0,0"/>
                            
                           
                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,20,0,15">
                                <Border Grid.Column="0" Height="1" Background="#E5E7EB" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"  Text="или" FontSize="12" Foreground="#9CA3AF" Margin="12,0"/>
                                <Border Grid.Column="2" Height="1" Background="#E5E7EB" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <Button Content="Создать аккаунт" Click="Button_Click" Background="White" BorderBrush="#667eea" BorderThickness="2" Foreground="#667eea" Height="44"/>
                        </StackPanel>
                        
                    </StackPanel>
                </Border>
            </Border>
        </ScrollViewer>
        
       
        <Border Grid.Row="2" Background="#1A252F" Padding="15"/>
       
    </Grid>
</Window>