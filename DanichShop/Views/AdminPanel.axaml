<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" MinHeight="1080" MinWidth="1920" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="DanichShop.AdminPanel"
        xmlns:vm="using:DanichShop.ViewModels"        
        x:DataType="vm:AdminViewModel"
        Title="{Binding WindowCaption}">
     
         <Window.DataContext>
        <vm:AdminViewModel/>
    </Window.DataContext>
 <Grid ColumnDefinitions="*,*">
 <TabControl Margin="10">
    <TabItem Header="Добавление товаров">
        <Grid>
        <StackPanel>
	 <TextBox Watermark="Название" Text="{Binding Title}"/>
     <TextBox Watermark="Описание" Text="{Binding Description}"/>
     <TextBox Watermark="Цена"  Text="{Binding Cost}"/>
     <TextBox Watermark="Количество" Text="{Binding Count}"/>
     <Button Content="Создать" Command="{Binding CreateItemCommand}"/>
      <TextBlock Text="Картинка товара:" FontWeight="Bold"/>
                             <TextBlock Text="Предпросмотр:" Margin="0,0,0,5"/>
                        <Image  Source="{Binding PicturePreview}" Width="200" Height="150" Stretch="Uniform"/>
      <Button Content="Обзор..."  Command="{Binding SelectImageCommand}"/>
             <TextBox Watermark="Поиск" Text="{Binding Searchadditem}"/> 
            <Button Content="Поиск" Command="{Binding SearchItemCommand}"/>
            

            <ScrollViewer Grid.Row="2" Grid.ColumnSpan="3" Margin="10">
            <ItemsControl ItemsSource="{Binding Itemssearch}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                     
                        <Border Width="220" Height="320" Background="White" Margin="8" BorderBrush="#e0e0e0" BorderThickness="1">
                            
                            <Grid RowDefinitions="160,Auto,Auto,Auto">
                                
                              
                                <Border Grid.Row="0" Background="White" >
                                    <Image Source="{Binding PictureImage}"  Stretch="Uniform" VerticalAlignment="Center" MaxHeight="140"/>
                                </Border>
                                
                               
                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="10,10,10,5" Foreground="#1a1a1a"/>
                                
                                
                                <TextBlock Grid.Row="2"  Text="{Binding Description}" FontSize="11"  TextWrapping="Wrap" Margin="10,0,10,5" Foreground="#666" MaxHeight="35"/>
                                
                           
                                <Grid Grid.Row="3" Margin="10,0,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Cost}"  FontSize="16"  FontWeight="Bold" Foreground="#cc0000" VerticalAlignment="Center"/>
                           
                                </Grid>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
 </StackPanel>
      </Grid>  
    </TabItem>

    <TabItem Header="Изменение товаров">
        <Grid ColumnDefinitions="*,*">
        <StackPanel Margin="5">
           
            <TextBox Watermark="Название"/>
          
            <TextBox Watermark="Описание"/>
            <TextBox Watermark="Цена"/>
            <TextBox Watermark="Количество"/>
            <TextBlock Text="Картинка товара:" FontWeight="Bold"/>
             <Button Content="Изменить"/>
                             <TextBlock Text="Предпросмотр:" Margin="0,0,0,5"/>
                        <Image  Source="{Binding PicturePreview}" Width="200" Height="150" Stretch="Uniform"/>
      <Button Content="Обзор..."  Command="{Binding SelectImageCommand}"/>
            <TextBox Watermark="Поиск" Text="{Binding Searchchangeitem}"/> 
            <Button Content="Поиск" Command="{Binding SearchItemCommand}"/>
       
            
            
            <ListBox ItemsSource="{Binding Itemschange}" SelectedItem="{Binding Selecteditem}" SelectionMode="Single" Margin="10" Height="500">
                <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
            <WrapPanel HorizontalAlignment="Left"/>
        </ItemsPanelTemplate>
    </ListBox.ItemsPanel>
    <ListBox.ItemTemplate>
        <DataTemplate>
                     
                        <Border Width="220" Height="320" Background="White" Margin="8" BorderBrush="#e0e0e0" BorderThickness="1">
                            
                            <Grid RowDefinitions="160,Auto,Auto,Auto">
                                
                              
                                <Border Grid.Row="0" Background="White" >
                                    <Image Source="{Binding PictureImage}"  Stretch="Uniform" VerticalAlignment="Center" MaxHeight="140"/>
                                </Border>
                                
                               
                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="10,10,10,5" Foreground="#1a1a1a"/>
                                
                                
                                <TextBlock Grid.Row="2"  Text="{Binding Description}" FontSize="11"  TextWrapping="Wrap" Margin="10,0,10,5" Foreground="#666" MaxHeight="35"/>
                                
                           
                                <Grid Grid.Row="3" Margin="10,0,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Cost}"  FontSize="16"  FontWeight="Bold" Foreground="#cc0000" VerticalAlignment="Center"/>
                                    
                                </Grid>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
             </StackPanel>
            </Grid>
    </TabItem>
    <TabItem Header="Пользователи">
        <StackPanel>
            <TextBox Watermark="Имя" Text="{Binding Changefname}"/>
            <TextBox Watermark="Фамилия" Text="{Binding Changesname}"/>
            <TextBox Watermark="Баланс" Text="{Binding Changebalance}"/>
            <TextBox Watermark="Бан" Text="{Binding Changeban}"/>
            <Button Content="Изменить" Command="{Binding ChangeUserCommand}"/>
            <TextBox Watermark="Поиск" Text="{Binding Searchchangeuser}"/> 
            <Button Content="Поиск" Command="{Binding SearchItemCommand}"/>
             <ListBox ItemsSource="{Binding Userschange}" SelectedItem="{Binding Selecteditem}" SelectionMode="Single" Margin="10" Height="500">
                <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
            <WrapPanel HorizontalAlignment="Left"/>
        </ItemsPanelTemplate>
    </ListBox.ItemsPanel>
    <ListBox.ItemTemplate>
        <DataTemplate>
                     
                        <Border Width="220" Height="320" Background="White" Margin="8" BorderBrush="#e0e0e0" BorderThickness="1">
                            
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                                              
                                
                               
                                <TextBlock Grid.Row="0" Text="{Binding Fname}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="10" Foreground="#1a1a1a"/>
                                <TextBlock Grid.Row="1"  Text="{Binding Sname}" FontSize="11"  TextWrapping="Wrap" Margin="10" Foreground="#666" MaxHeight="35"/>
                                <TextBlock Grid.Row="2"  Text="{Binding Telephone}" FontSize="11"  TextWrapping="Wrap" Margin="10" Foreground="#666" MaxHeight="35"/>
                                <TextBlock Grid.Row="3"  Text="{Binding Email}" FontSize="11"  TextWrapping="Wrap" Margin="10" Foreground="#666" MaxHeight="35"/>
                                <TextBlock Grid.Row="4"  Text="{Binding Ban}" FontSize="11"  TextWrapping="Wrap" Margin="10" Foreground="#666" MaxHeight="35"/>
                                <TextBlock Grid.Row="5"  Text="{Binding Balance}" FontSize="11"  TextWrapping="Wrap" Margin="10" Foreground="#666" MaxHeight="35"/>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </StackPanel>
    </TabItem>
</TabControl>     
    



 
 
 
 </Grid>
</Window>
