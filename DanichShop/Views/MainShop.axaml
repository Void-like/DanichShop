<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="DanichShop.MainShop"
        Title="MainShop">
    <Window.Styles>		
		<Style Selector="Button.selector">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Height" Value="100"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="5"/>
        </Style>

        <Style Selector="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>


  <Grid RowDefinitions="*, Auto">

           <ContentControl x:Name="ContentPage" Margin="0"/>

	 <Border Grid.Row="1" Background="White" BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Padding="0,10,0,10">
            <Grid ColumnDefinitions="*, *, *">
                
              

                <StackPanel Grid.Column="0"> 
                      <Button Classes="selector" Content="Каталог" Click="Button_Click_1"/>     
                </StackPanel>

                  <StackPanel Grid.Column="1">
                     <Button Classes="selector"  Content="Корзина" Click="Button_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2">                  
                      <Button Classes="selector" Content="Аккаунт" Click="Button_Click_2"/>
                </StackPanel>

            </Grid>
            </Border>  


  </Grid>
</Window>
